generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url-ja tani konfigurohet te prisma.config.ts (Prisma 7)
}

// ============================================================
//  ADMIN / AUTH
// ============================================================
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hash bcrypt
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
//  PRODUKTET
// ============================================================
model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  shortDesc      String? // teksti i shkurtër poshtë çmimit
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  // Çmimet e transportit / teksti i transportit
  shippingNote   String?
  // Përshkrimi i gjatë (HTML/markdown i thjeshtë)
  description    String?
  // Stoku
  stock          Int      @default(0)
  sku            String?
  active         Boolean  @default(true)
  featured       Boolean  @default(false) // shfaqet në homepage si një nga 3 boxat
  sortOrder      Int      @default(0)

  // ages, recommendation etj.
  ageRange String?

  images    ProductImage[]
  // Karakteristikat (bullets) p.sh. "6 kategori edukative"
  bullets   ProductBullet[]
  // Seksioni "Çka mësojmë nga kartat?" / kategoritë
  features  ProductFeature[]
  // Seksioni "Informacion rreth produktit" (kartela me ikona)
  infoCards ProductInfoCard[]
  // FAQ specifike për produktin
  faqs      ProductFaq[]

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model ProductBullet {
  id        String  @id @default(cuid())
  text      String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model ProductFeature {
  id        String  @id @default(cuid())
  title     String
  body      String?
  imageUrl  String?
  colorTag  String? // ngjyra e background-it të kartës
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model ProductInfoCard {
  id        String  @id @default(cuid())
  label     String // p.sh. "180 karta", "14 x 11 cm"
  imageUrl  String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model ProductFaq {
  id        String  @id @default(cuid())
  question  String
  answer    String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

// ============================================================
//  POROSITË
// ============================================================
enum OrderStatus {
  PENDING // pranuar, pa procesuar
  CONFIRMED // konfirmuar
  SHIPPED // dërguar
  DELIVERED // dorëzuar
  CANCELLED // anuluar
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)

  // Të dhënat e klientit (guest checkout)
  firstName String
  lastName  String
  email     String?
  phone     String
  city      String
  address   String
  country   String
  note      String?

  // Pagesa
  paymentMethod String @default("COD") // Cash on Delivery

  subtotal Decimal @db.Decimal(10, 2)
  shipping Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  name      String // snapshot i emrit
  price     Decimal  @db.Decimal(10, 2) // snapshot i çmimit
  quantity  Int
}

// ============================================================
//  BLOGU
// ============================================================
model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  coverImage  String?
  content     String // HTML
  author      String?  @default("FLETËZA")
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
//  KONTENTI I HOMEPAGE / FAQE (i editueshëm nga admini)
// ============================================================

// Pse FLETËZA? — kartat e arsyeve
model HomeReason {
  id        String  @id @default(cuid())
  title     String
  body      String
  imageUrl  String?
  sortOrder Int     @default(0)
}

// "Të konceptuara nga ekspertë" — logopedë, psikologë etj.
model ExpertCard {
  id        String  @id @default(cuid())
  label     String
  imageUrl  String?
  sortOrder Int     @default(0)
}

// Reviews / vlerësimet e prindërve
model Review {
  id         String  @id @default(cuid())
  authorName String
  text       String
  rating     Int     @default(5)
  imageUrl   String?
  sortOrder  Int     @default(0)
}

// "Momente të ndara nga prindërit" — galeria
model MomentMedia {
  id        String @id @default(cuid())
  imageUrl  String
  sortOrder Int    @default(0)
}

// FAQ global (jo per produkt)
model Faq {
  id        String @id @default(cuid())
  question  String
  answer    String
  sortOrder Int    @default(0)
}

// Cilësime të përgjithshme të faqes (key-value)
model SiteSetting {
  key   String @id
  value String
}

// Mesazhet nga forma e kontaktit
model ContactMessage {
  id        String   @id @default(cuid())
  name      String?
  email     String
  phone     String?
  message   String
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())
}
