# ---- Baza e të dhënave (PostgreSQL) ----
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fleteza?schema=public"

# ---- Sesioni i adminit (gjeneroni një string të rastësishëm të gjatë) ----
AUTH_SECRET="ndrysho-kete-ne-nje-sekret-shume-te-gjate-dhe-te-rastesishem"

# ---- Email (Gmail SMTP me App Password) ----
# Aktivizo 2FA në Gmail dhe krijo një "App Password": https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="emaili.juaj@gmail.com"
SMTP_PASS="app-password-16-shkronjor"
MAIL_FROM="FLETËZA <emaili.juaj@gmail.com>"
ADMIN_EMAIL="info@fleteza.com"

# ---- Të dhënat fillestare të adminit (përdoren nga seed) ----
SEED_ADMIN_EMAIL="admin@fleteza.com"
SEED_ADMIN_PASSWORD="Fleteza123!"

# ---- URL publike e faqes (për lidhjet në email) ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
